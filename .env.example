# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Required: Flightradar24 API token (from Key management in the API portal).
FR24_API_TOKEN=

# Optional: fixed password that gates the whole site. Leave blank to disable.
SITE_PASSWORD=

# Default flight number shown on first load (e.g. KE41, SK1415).
DEMO_FLIGHT=KE41

# How many days back from now (UTC) to query flight history (max 14 per FR24 flight-summary docs).
DEMO_LOOKBACK_DAYS=14

# Default airport ICAO shown when no airport param is provided (used by /api/airport).
DEMO_AIRPORT=SEA

# Dev/test: shrink the airport analysis window to save API credits (1-24, default 24).
# DEV_WINDOW_HOURS=3
