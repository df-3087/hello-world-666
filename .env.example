# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Required: Flightradar24 API token (from Key management in the API portal).
FR24_API_TOKEN=

# Optional: fixed password that gates the whole site. Leave blank to disable.
SITE_PASSWORD=

# Demo scope: one airport (IATA 3 letters or ICAO 4 letters), e.g. ARN or ESSA
DEMO_AIRPORT=SEA

# Demo scope: one flight number as used in the FR24 /flight-summary API, e.g. SK1415
DEMO_FLIGHT=KE41

# How many days back from now (UTC) to query flight summary (max 14 per FR24 flight-summary docs)
DEMO_LOOKBACK_DAYS=7
